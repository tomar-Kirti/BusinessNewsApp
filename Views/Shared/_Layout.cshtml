<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BusinessNewsApp</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lora:ital@0;1&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <style>
        body {
            background-color: #f5f0e8;
            font-family: 'Source Sans 3', sans-serif;
        }

        .newspaper-banner {
            text-align: center;
            padding: 1.5rem 0 1rem;
            border-top: 4px solid #1a1a1a;
            border-bottom: 4px solid #1a1a1a;
            margin-bottom: 0;
        }

        .newspaper-banner h1 {
            font-family: 'Playfair Display', serif;
            font-size: 3.5rem;
            font-weight: 700;
            letter-spacing: 0.05em;
            color: #1a1a1a;
            margin: 0;
        }

        .dateline-bar {
            background-color: #1a1a1a;
            color: #f5f0e8;
            text-align: center;
            padding: 0.35rem 0;
            font-family: 'Source Sans 3', sans-serif;
            font-size: 0.8rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 0;
        }

        .navbar {
            background-color: #f5f0e8 !important;
            box-shadow: none !important;
            border-bottom: 1px solid #c9b99a !important;
        }

        .navbar .nav-link {
            font-family: 'Source Sans 3', sans-serif;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.1em;
            color: #1a1a1a !important;
        }

        .navbar-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem;
            color: #1a1a1a !important;
        }

        .section-rule {
            border-top: 3px double #1a1a1a;
            margin: 0;
        }
    </style>
</head>
<body>
    <header>
        <div class="newspaper-banner">
            <h1>The Business Chronicle</h1>
        </div>
        <div class="dateline-bar">
            @DateTime.Now.ToString("dddd, MMMM d, yyyy") &nbsp;&bull;&nbsp; Top US Business Headlines
        </div>
        <nav class="navbar navbar-expand-sm navbar-light">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">BusinessNewsApp</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
        <div class="section-rule"></div>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmA+7KzHW9mzNY3JeGbKXbSg5qw" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
