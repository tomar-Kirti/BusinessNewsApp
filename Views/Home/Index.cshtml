@model List<BusinessNewsApp.Models.Article>

@{
    ViewData["Title"] = "Top US Business News";
}

<div class="container mt-4">
    <h1 class="mb-1">Top US Business Headlines</h1>
    <p class="text-muted mb-4">Latest business news powered by NewsAPI</p>

    @if (ViewBag.ApiError != null)
    {
        <div class="alert alert-danger">
            <strong>API request failed.</strong> @ViewBag.ApiError
        </div>
    }
    else if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">
            No articles found. Please check your API key in appsettings.json.
        </div>
    }
    else
    {
        @foreach (var article in Model)
        {
            <div class="mb-3">
                <!-- Source name displayed in bold -->
                <p class="mb-1"><strong>@article.Source.Name</strong></p>

                <!-- Article title as a clickable link opening in a new tab -->
                <a href="@article.Url" target="_blank" rel="noopener noreferrer">
                    @article.Title
                </a>
            </div>
            <hr />
        }
    }
</div>
